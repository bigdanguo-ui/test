{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI CAD Preview API",
    "description": "CadQuery primitives exposed through FastAPI and OpenAPI.",
    "version": "0.1.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/models": {
      "get": {
        "summary": "List Models",
        "operationId": "list_models_api_models_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelCatalogResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/models/{shape_type}": {
      "get": {
        "summary": "Read Model",
        "operationId": "read_model_api_models__shape_type__get",
        "parameters": [
          {
            "name": "shape_type",
            "in": "path",
            "required": true,
            "schema": {
              "enum": [
                "box",
                "sphere",
                "cylinder"
              ],
              "type": "string",
              "description": "Primitive model type to preview.",
              "title": "Shape Type"
            },
            "description": "Primitive model type to preview."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/BoxPreview"
                    },
                    {
                      "$ref": "#/components/schemas/SpherePreview"
                    },
                    {
                      "$ref": "#/components/schemas/CylinderPreview"
                    }
                  ],
                  "discriminator": {
                    "propertyName": "shape_type",
                    "mapping": {
                      "box": "#/components/schemas/BoxPreview",
                      "sphere": "#/components/schemas/SpherePreview",
                      "cylinder": "#/components/schemas/CylinderPreview"
                    }
                  },
                  "title": "Response Read Model Api Models  Shape Type  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/models/preview": {
      "post": {
        "summary": "Preview Model",
        "operationId": "preview_model_api_models_preview_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/BoxPreviewRequest"
                  },
                  {
                    "$ref": "#/components/schemas/SpherePreviewRequest"
                  },
                  {
                    "$ref": "#/components/schemas/CylinderPreviewRequest"
                  }
                ],
                "title": "Request",
                "description": "Primitive parameters to rebuild with CadQuery."
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/BoxPreview"
                    },
                    {
                      "$ref": "#/components/schemas/SpherePreview"
                    },
                    {
                      "$ref": "#/components/schemas/CylinderPreview"
                    }
                  ],
                  "title": "Response Preview Model Api Models Preview Post",
                  "discriminator": {
                    "propertyName": "shape_type",
                    "mapping": {
                      "box": "#/components/schemas/BoxPreview",
                      "sphere": "#/components/schemas/SpherePreview",
                      "cylinder": "#/components/schemas/CylinderPreview"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
